<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/engine_match_engine1"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/engine_match_spinner1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/engine_match_engine2"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/engine_match_spinner2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/engine_match_time"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/engine_match_time_edit"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="60" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/engine_match_increment"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/engine_match_inc_edit"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/engine_match_num_games"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/engine_match_games_edit"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="2" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/engine_match_opening_source"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/engine_match_opening_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/engine_match_radio_start_pos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/engine_match_from_start"
                android:checked="true" />

            <RadioButton
                android:id="@+id/engine_match_radio_current_pos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/engine_match_use_current_pos" />

            <RadioButton
                android:id="@+id/engine_match_radio_book"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/engine_match_use_book" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/engine_match_book_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingLeft="16dp"
            android:layout_marginBottom="8dp">

            <Spinner
                android:id="@+id/engine_match_book_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/engine_match_max_plies"
                    android:gravity="center_vertical" />

                <EditText
                    android:id="@+id/engine_match_max_plies_edit"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="20" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/engine_match_pgn_order_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/engine_match_pgn_order"
                    android:gravity="center_vertical" />

                <Spinner
                    android:id="@+id/engine_match_pgn_order_spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/engine_match_max_moves"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/engine_match_max_moves_edit"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="200" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/engine_match_auto_adjudicate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/engine_match_auto_adjudicate"
            android:checked="false"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:id="@+id/engine_match_adjudication_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingLeft="16dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/engine_match_draw_threshold"
                    android:gravity="center_vertical" />

                <EditText
                    android:id="@+id/engine_match_draw_cp_edit"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="10" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/engine_match_resign_threshold"
                    android:gravity="center_vertical" />

                <EditText
                    android:id="@+id/engine_match_resign_cp_edit"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="500" />
            </LinearLayout>
        </LinearLayout>

        <CheckBox
            android:id="@+id/engine_match_alternate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/engine_match_alternate_colors"
            android:checked="true" />

        <CheckBox
            android:id="@+id/engine_match_keep_screen_on"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/engine_match_keep_screen_on"
            android:checked="false" />

    </LinearLayout>
</ScrollView>
